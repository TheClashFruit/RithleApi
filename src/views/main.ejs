<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Rithle &bull; <%= page.title %></title>

    <link rel="stylesheet" href="/fonts/cantarell/cantarell.css" />

    <style>
      :root {
        color-scheme: light dark;
      }

      * {
        margin: 0;
        padding: 0;

        box-sizing: border-box;
      }

      body {
        max-width: 75ch;

        margin: 0 auto;

        font-family: "Cantarell", sans-serif;
        font-size: 100%;
        font-weight: 400;

        line-height: 1.5;
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: "Cantarell", sans-serif;
        font-weight: 500;

        margin-bottom: 8px;
      }

      h1 {
        font-size: 200%;
      }

      h2 {
        font-size: 180%;
      }

      h3 {
        font-size: 160%;
      }

      h4 {
        font-size: 140%;
      }

      h5 {
        font-size: 125%;
      }

      h6 {
        font-size: 110%;
      }

      p {
        margin-bottom: 8px;

        text-align: justify;
        text-justify: inter-word;

        &:last-child {
          margin-bottom: 0;
        }
      }

      small {
        font-size: 80%;
      }

      ul,
      ol {
        margin-bottom: 8px;
        margin-left: 32px;

        &:last-child {
          margin-bottom: 0;
        }
      }

      img {
        max-width: 100%;
      }

      footer,
      header {
        margin-top: 16px;
        margin-bottom: 16px;
      }

      footer {
        display: flex;

        align-items: center;
        justify-content: space-between;

        p {
          margin: 0;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <h1 style="margin-bottom: 0">Rithle</h1>
      <h2 style="margin-top: 0"><%= page.title %></h2>

      <nav>
        <a href="/">Stats</a>
        &middot;
        <a href="/privacy">Privacy Policy</a>
        &middot;
        <a href="https://github.com/TheClashFruit/Rithle/releases"
          >Download Rithle on GitHub</a
        >
      </nav>
    </header>

    <main><%- page.content %></main>

    <footer>
      <p>
        Copyright &copy; <%= new Date().getFullYear() %>
        <a href="https://theclashfruit.me">TheClashFruit</a>.
      </p>

      <p>
        <a href="/opt-out">Delete My Data</a>
      </p>
    </footer>
  </body>
</html>
